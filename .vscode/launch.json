{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Django: runserver",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/backend/manage.py",
      "args": ["runserver"],
      "django": true,
      "env": {
        "DJANGO_SETTINGS_MODULE": "config.settings"
      },
      "cwd": "${workspaceFolder}/backend"
    }
  ]
}
